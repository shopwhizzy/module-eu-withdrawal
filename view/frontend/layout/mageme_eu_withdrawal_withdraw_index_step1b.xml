<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="content">
            <block class="MageMe\EUWithdrawal\Block\Withdraw\ProgressStepper"
                   name="mageme_eu_withdrawal.stepper.step1b"
                   template="MageMe_EUWithdrawal::withdraw/progress_stepper.phtml">
                <arguments>
                    <argument name="active_step" xsi:type="number">1</argument>
                </arguments>
            </block>
            <block class="MageMe\EUWithdrawal\Block\Withdraw\OrderSelector"
                   name="mageme_eu_withdrawal.order_selector_list"
                   cacheable="false"
                   template="MageMe_EUWithdrawal::withdraw/step1b_order_list.phtml">
                <block class="MageMe\EUWithdrawal\Block\Withdraw\OrderSelector"
                       name="mageme_eu_withdrawal.order_rows"
                       as="order_rows"
                       cacheable="false"
                       template="MageMe_EUWithdrawal::withdraw/step1b_orders_rows.phtml"/>
            </block>
        </referenceContainer>
    </body>
</page>
