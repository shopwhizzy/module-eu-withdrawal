                    </tbody>
                <?php else: ?>
                    <?php $rowIndex = 0; foreach ($items as $item): ?>
                        <?php
                        $rowIndex++;
                        $orderItem = $block->getOrderItem((int) $item->getOrderItemId());
                        $eligibility = (string) $item->getEligibility();
                        ?>
                        <tbody class="<?= /* @noEscape */ $rowIndex % 2 ? 'even' : 'odd' ?>">
                            <tr>
                                <td class="col-product">
                                    <?php if ($orderItem !== null): ?>
                                        <div class="product-title">
                                            <?= $escaper->escapeHtml((string) $orderItem->getName()) ?>
                                        </div>
                                    <?php endif; ?>
                                    <div class="product-sku-block">
                                        <span><?= $escaper->escapeHtml(__('SKU')) ?>:</span>
                                        <?= $escaper->escapeHtml((string) $item->getSku()) ?>
                                    </div>
                                </td>
                                <td class="col-price">
                                    <?= $escaper->escapeHtml(
                                        $orderItem !== null
                                            ? $block->formatPrice((float) $orderItem->getPrice())
                                            : '—'
                                    ) ?>
                                </td>
                                <td class="col-ordered-qty">
                                    <table class="qty-table">
                                        <?php if ($orderItem !== null): ?>
                                            <tr>
                                                <th><?= $escaper->escapeHtml(__('Ordered')) ?></th>
                                                <td><?= (float) $orderItem->getQtyOrdered() ?></td>
                                            </tr>
                                        <?php endif; ?>
                                        <tr>
                                            <th><?= $escaper->escapeHtml(__('Withdrawing')) ?></th>
                                            <td><?= (float) $item->getQtyWithdraw() ?></td>
                                        </tr>
                                    </table>
                                </td>
                                <td class="col-subtotal">
                                    <?= $escaper->escapeHtml(
                                        $orderItem !== null
                                            ? $block->formatPrice((float) $orderItem->getRowTotal())
                                            : '—'
                                    ) ?>
                                </td>
                                <td class="col-refund">
                                    <?= $escaper->escapeHtml($block->formatPrice((float) $item->getRefundAmount())) ?>
                                </td>
                                <td class="col-reason">
                                    <?= $escaper->escapeHtml($block->getItemReasonDisplay($item)) ?>
                                </td>
                                <td class="col-eligibility last">
                                    <?= $escaper->escapeHtml(__(ucwords(str_replace('_', ' ', $eligibility)))) ?>
                                </td>
                            </tr>
                        </tbody>
                    <?php endforeach; ?>
                <?php endif; ?>
            </table>
        </div>
    </div>
</section>

<?php
